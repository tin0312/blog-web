<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style/main.css">
    <title>Blog</title>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>

<body>
    <nav>
        <!-- Desktop Navigation Bar -->
        <ul class="desktop-nav">
            <li><a class="nav-link" href="/">posts</a></li>
            <% if(!locals.isAuthenticated) { %>
                <li><a href="/emailLogin">
                        <img class="user-icon" src="/icon/user.png" alt="user-icon" />
                    </a>
                <li><a class="nav-link create-post-btn" href="/register">Register</a></li>
                </li>
                <% } else {%>
                    <li><a class="nav-link create-post-btn" href="/create-post">Create Post</a></li>
                    <li><a href="/log-out">
                            <img class="user-icon" src="/icon/log-out.png" alt="user-icon" />

                        </a>
                    </li>
                    <%} %>
        </ul>
        <!-- Menu icon -->
        <span class="nav-icon hide">
            <i></i>
            <i></i>
            <i></i>
        </span>
        <!-- Mobile Navigation Bar -->
        <ul class="mobile-nav hide">
            <li><a class="nav-link" href="/">posts</a></li>
            <% if(!locals.isAuthenticated) { %>
                <li><a href="/emailLogin">
                        <img class="user-icon" src="/icon/user.png" alt="user-icon" />
                <li><a class="nav-link create-post-btn" href="/register">Register</a></li>
                </a>
                </li>
                <% } else {%>
                    <li><a class="nav-link create-post-btn" href="/create-post">Create Post</a></li>
                    <li><a href="/log-out">
                            <img class="user-icon" src="/icon/log-out.png" alt="user-icon" />

                        </a>
                    </li>
                    <%} %>
        </ul>
    </nav>